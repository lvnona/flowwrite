<?xml version="1.0" encoding="utf-8"?>
<!--
    FlowWrite bubble glyph — a stylized "flow + pen" mark.
    Two flowing wave strokes (the "flow") crossed by a pen-nib tip (the "write").
    White on the coloured bubble background.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="28dp"
    android:height="28dp"
    android:viewportWidth="48"
    android:viewportHeight="48">

    <!-- Lower flow wave -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3.2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M7,30
                          C14,22 20,38 27,30
                          C32,24 36,28 41,24" />

    <!-- Upper flow wave -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3.2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M7,20
                          C14,12 20,28 27,20" />

    <!-- Pen-nib spark / tip -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M36,10
                          l4.2,1.6
                          l-1.6,4.2
                          l-4.2,-1.6
                          z" />
</vector>
