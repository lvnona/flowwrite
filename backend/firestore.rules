rules_version = '2';

// FlowWrite Firestore security rules — Architecture A (no Cloud Functions).
//
// Roles:
//   owner — the authenticated user (reads/updates own doc, increments usage)
//   admin — hardcoded UID (full read/write/delete on all user docs)
//
// Schema fields that only admins may change: plan, status, expiresAt.

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow get:    if isOwner(userId) || isAdmin();
      allow list:   if isAdmin();

      // First sign-in: client creates doc. Plan must be 'free', status 'active'.
      allow create: if isOwner(userId)
        && request.resource.data.plan   == 'free'
        && request.resource.data.status == 'active';

      // Regular user: may update profile fields and usage counters only.
      // plan / status / expiresAt are admin-only.
      allow update: if
        (isOwner(userId)
          && request.resource.data.plan      == resource.data.plan
          && request.resource.data.status    == resource.data.status
          && request.resource.data.expiresAt == resource.data.expiresAt)
        || isAdmin();

      // Only admin can delete a user record.
      allow delete: if isAdmin();

      // Per-user templates, synced across the user's devices. Owner-only
      // (admin may also read for support).
      match /templates/{templateId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Invite records created from the admin panel. Admin-only — invited users
    // never touch this (they just download the app and sign in with Google).
    match /invites/{inviteId} {
      allow read, create, update, delete: if isAdmin();
    }

    // Admin-managed API keys (Anthropic + OpenAI). The Electron app reads this
    // doc via onSnapshot and pushes the keys into the main process — customers
    // never see or enter them through the UI. Write is admin-only.
    match /config/apiKeys {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // Server-side billing + email configuration (Stripe keys, price, webhook
    // secret, SMTP credentials, owner-alert email, URLs). Edited from the admin
    // panel; read by the PHP backend via the service account (which bypasses
    // these rules). Contains SECRETS — admin-only read, NOT "any signed-in user".
    match /config/billing {
      allow read, write: if isAdmin();
    }

    // The admin list ({ uids: [...] }). Any admin may read it (so the panel can
    // show it); ONLY the permanent super-admin may change it.
    match /config/admins {
      allow read:  if isAdmin();
      allow write: if isSuperAdmin();
    }

    // Free-plan weekly limits (popup generations + dictated words). Read by
    // every signed-in user so the app can enforce + display them; admin-only
    // write so customers can't loosen their own limits.
    match /config/limits {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }

  function isOwner(userId) {
    return request.auth != null && request.auth.uid == userId;
  }

  // Permanent super-admin (lvnona@gmail.com) — can never be removed and is the
  // only account allowed to edit the admin list.
  function isSuperAdmin() {
    return request.auth != null &&
      request.auth.uid == 'B8npzkB2vdh2DSf52wHZfNmBSS92';
  }

  // Additional admins are stored in config/admins as { uids: [...] }.
  function isListedAdmin() {
    return request.auth != null
      && exists(/databases/(default)/documents/config/admins)
      && request.auth.uid in get(/databases/(default)/documents/config/admins).data.get('uids', []);
  }

  function isAdmin() {
    return isSuperAdmin() || isListedAdmin();
  }
}
