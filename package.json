{
  "name": "flowwrite",
  "version": "0.1.6",
  "description": "AI writing assistant that lives in your system tray and helps fill any text field with Claude-generated content.",
  "main": "electron/main.js",
  "type": "module",
  "author": "FlowWrite",
  "license": "MIT",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "dev": "concurrently -k -n VITE,ELECTRON -c cyan,magenta \"npm:dev:vite\" \"npm:dev:electron\"",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "package:mac": "npm run build:renderer && electron-builder --mac",
    "package:win": "npm run build:renderer && electron-builder --win",
    "start": "electron ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@electron/remote": "^2.1.2",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.0",
    "firebase": "^12.13.0",
    "framer-motion": "^11.11.0",
    "openai": "^6.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.flowwrite.app",
    "productName": "FlowWrite",
    "files": [
      "electron/**/*",
      "dist/index.html",
      "dist/assets/**/*",
      "public/**/*"
    ],
    "directories": {
      "buildResources": "build"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "hardenedRuntime": true,
      "icon": "public/icons/app-icon.png",
      "artifactName": "FlowWrite-mac.${ext}",
      "x64ArchFiles": "fn-monitor",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "FlowWrite uses your microphone for voice dictation — your speech is transcribed into text you can edit."
      },
      "extraResources": [
        {
          "from": "electron/native/fn-monitor",
          "to": "fn-monitor"
        }
      ]
    },
    "dmg": {
      "artifactName": "FlowWrite-mac.${ext}"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icons/app-icon.ico",
      "artifactName": "FlowWrite-win-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "FlowWrite-win-setup.${ext}"
    }
  }
}
